# audio-proxy — copy to .env and fill in (or resolve from your secret manager).
# Bun auto-loads .env at startup.

# Local listen port (matches the Caddy *.test entry).
PORT=7716

# IU unified audio endpoint, OpenAI dialect. Real host + key live in 1Password
# (op://common/anthropic — API_KEY / OPENAI_BASE_URL). Never commit the real values.
IU_OPENAI_BASE_URL=https://<iu-endpoint>/openai/v1
IU_API_KEY=

# Local SQLite usage log (created on first run).
USAGE_DB=./data/usage.db

# Optional: if set, clients must send `Authorization: Bearer <this>`.
# Leave empty to accept any caller — only safe when bound to localhost.
PROXY_API_KEY=

# STT language steering (injected only when the client sends none).
# STT_LANGUAGE: hard lock to ONE language (ISO-639-1, e.g. `de`) — most reliable,
#   but wrong-language audio is forced into it. Leave empty to allow multiple.
# STT_PROMPT: soft bias — use this to keep gpt-4o-transcribe from drifting into
#   exotic languages (Chinese/Dutch) on short/quiet clips while still allowing
#   both German and English. OpenAI's own recommendation for multi-language.
STT_LANGUAGE=
STT_PROMPT=Die Aufnahme ist auf Deutsch oder Englisch.
