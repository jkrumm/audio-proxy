<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>com.jkrumm.audio-proxy</string>
  <key>ProgramArguments</key>
  <array>
    <string>__HOME__/SourceRoot/audio-proxy/launchd/start-audio-proxy.sh</string>
  </array>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key><string>__HOME__</string>
  </dict>
  <key>WorkingDirectory</key><string>__HOME__/SourceRoot/audio-proxy</string>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/tmp/audio-proxy.log</string>
  <key>StandardErrorPath</key><string>/tmp/audio-proxy.err</string>
</dict>
</plist>
